{
	"name": "docker-wingman",
	"displayName": "Docker Wingman",
	"description": "Help programmers use environments without memorising docker commands.",
	"version": "1.0.0",
	"publisher": "DJSaunders1997",
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": [
		"Other",
		"Snippets",
		"Data Science",
		"Machine Learning"
	],
	"icon": "images/Logo-Banner.png",
	"galleryBanner": {
		"color": "#0db7ed",
		"theme": "dark"
	},
	"keywords": [
		"Docker",
		"Wingman",
		"Container",
		"Dockerfile",
		"Environment"
	],
	"preview": false,
	"activationEvents": [
		"onLanguage:dockerfile",
		"onCommand:docker-wingman.buildDockerfile",
		"onCommand:docker-wingman.runDockerfile",
		"onCommand:docker-wingman.deleteDockerEnv"
	],
	"main": "./src/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "docker-wingman.buildDockerfile",
				"title": "Docker Wingman: Build Docker Image from Dockerfile"
			},
			{
				"command": "docker-wingman.runDockerfile",
				"title": "Docker Wingman: Run Docker Container from Image"
			},
			{
				"command": "docker-wingman.deleteDockerEnv",
				"title": "Docker Wingman: Stop and Remove Docker Container"
			}
		],
		"configuration": {
			"title": "Docker Wingman",
			"properties": {
				"dockerWingman.showStatusBarItems": {
					"type": "boolean",
					"default": true,
					"description": "Show Docker Wingman status bar items when a Dockerfile is open."
				}
			}
		}
	},
	"scripts": {
		"lint": "eslint src/ test/",
		"pretest": "npm run lint",
		"test": "node ./test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.1",
		"@types/node": "^22.8.7",
		"@types/vscode": "^1.95.0",
		"@vscode/test-electron": "^2.4.1",
		"eslint": "^9.14.0",
		"glob": "^11.0.0",
		"mocha": "^10.2.0",
		"sinon": "^19.0.2",
		"typescript": "^5.6.3",
		"@vscode/vsce": "^3.2.1"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/DJSaunders1997/docker-wingman.git"
	},
	"homepage": "https://github.com/DJSaunders1997/docker-wingman#readme",
	"dependencies": {
	}
}
